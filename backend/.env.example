# ============================================================
# Variables d'environnement — backend (copier en .env et remplir)
# ============================================================

ENV=development
FRONTEND_ORIGIN=http://localhost:3000

# ---- Supabase (gratuit, sans carte bancaire — supabase.com) ----
# Project Settings > API dans le dashboard Supabase
SUPABASE_URL=https://VOTRE-PROJET.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# ---- Google Calendar (gratuit — console.cloud.google.com) ----
# Créer un projet > activer "Google Calendar API" > Identifiants OAuth2
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/calendar/oauth/callback

# ---- LLM (agents) ----
# groq = gratuit, sans carte bancaire (RECOMMANDÉ) — clé sur console.groq.com/keys
# anthropic / openai = payants, optionnels, à n'activer que si vous le décidez
LLM_PROVIDER=groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# ---- Transcription audio ----
# local = faster-whisper, 100% gratuit, tourne sur CPU (RECOMMANDÉ)
TRANSCRIPTION_PROVIDER=local
WHISPER_MODEL_SIZE=small
